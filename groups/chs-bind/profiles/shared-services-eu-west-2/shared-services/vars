# Account details

aws_account = "shared-services"
aws_region  = "eu-west-2"
environment = "shared-services"
dns_zone    = "sharedservices.aws.internal"

# Instance details

instance_count = "3"
instance_type = "t3.medium"
root_volume_size = 25
service = "postfix"
service_subtype = "postfix"
application_subnet_pattern = "sub-application-*"
default_log_retention_in_days = "7"
monitoring = true
